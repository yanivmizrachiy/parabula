{
  "name": "parabula",
  "private": true,
  "type": "module",
  "dependencies": {
    "imagetracerjs": "^1.2.6",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "tesseract.js": "^6.0.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "node preview/server.mjs",
    "preview:vite": "vite preview --port 4173 --strictPort",
    "preview:check": "node scripts/preview-check.mjs",
    "page:new": "node scripts/new-page.mjs",
    "test": "node --test",
    "verify": "npm test && npm run preview:check",
    "test:watch:page": "node scripts/test-watch.mjs --testFile tests/עמוד-2.test.mjs",
    "ocr:pythagoras:1-3": "node scripts/ocr-pythagoras.mjs --pages 1,2,3",
    "meta:check": "node scripts/validate-meta.mjs",
    "visual:test": "node scripts/visual-regression.mjs",
    "verify:super": "npm run meta:check && npm run visual:test"
  },
  "devDependencies": {
    "puppeteer": "^24.37.5",
    "vite": "^7.3.1",
    "ajv": "^8.17.1",
    "playwright": "^1.58.2"
  }
}
