{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: start vite",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*(>\\s*vite\\b|VITE\\s+v)",
          "endsPattern": "Local:\\s+http://localhost:5173/"
        }
      }
    }
  ]
}
